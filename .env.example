# FLOCKED — environment for the AI sidecar (services/ai-sidecar)
# Copy to .env and fill in. The browser NEVER sees these.

# Required for the live Claude world generator (Phase 2) + predator brain (Phase 3).
# Without it, the sidecar uses the deterministic MOCK generator and still runs end-to-end.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# STDB_URI=ws://localhost:3000
# STDB_DB=flocked
